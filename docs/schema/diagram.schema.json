{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://model-editor.example.com/schemas/diagram/v1.json",
  "title": "Model Editor Diagram Schema",
  "description": "JSON Schema for Analysis Pattern model diagram (Martin Fowler notation), version 1.0",
  "type": "object",
  "required": ["version", "elements"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version",
      "pattern": "^\\d+\\.\\d+$",
      "default": "1.0"
    },
    "metadata": {
      "type": "object",
      "description": "Optional diagram metadata",
      "properties": {
        "title": {
          "type": "string",
          "description": "Diagram title"
        },
        "createdAt": {
          "type": "number",
          "description": "Creation timestamp (milliseconds since epoch)"
        },
        "updatedAt": {
          "type": "number",
          "description": "Last update timestamp (milliseconds since epoch)"
        },
        "author": {
          "type": "string",
          "description": "Author name or identifier"
        }
      },
      "additionalProperties": true
    },
    "elements": {
      "type": "array",
      "description": "Array of all diagram elements",
      "items": {
        "oneOf": [
          { "$ref": "#/definitions/typeElement" },
          { "$ref": "#/definitions/relationElement" },
          { "$ref": "#/definitions/generalizationElement" },
          { "$ref": "#/definitions/noteElement" }
        ]
      }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "layout": {
      "description": "Layout information (rendering coordinates and size) - separate from semantics",
      "type": "object",
      "required": ["x", "y", "width", "height"],
      "properties": {
        "x": {
          "type": "number",
          "description": "X coordinate of top-left corner"
        },
        "y": {
          "type": "number",
          "description": "Y coordinate of top-left corner"
        },
        "width": {
          "type": "number",
          "description": "Width in pixels"
        },
        "height": {
          "type": "number",
          "description": "Height in pixels"
        }
      },
      "additionalProperties": false
    },
    "point": {
      "type": "object",
      "required": ["x", "y"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      },
      "additionalProperties": false
    },
    "cardinality": {
      "type": "string",
      "enum": [
        "exactly_one",
        "zero_or_one",
        "one_or_more",
        "zero_or_more",
        "two_or_more",
        "range",
        "unknown",
        "no_mapping"
      ],
      "description": "Cardinality constraint type"
    },
    "shortSemantic": {
      "description": "Short semantic statement marker. Uses a discriminated union on `kind` to allow markers with parameters (e.g. key type, explicit range bounds).",
      "oneOf": [
        {
          "type": "object",
          "required": ["kind"],
          "additionalProperties": false,
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "abstract",
                "immutable",
                "singleton",
                "list",
                "class",
                "hierarchy",
                "dag",
                "multiple_hierarchies",
                "historic"
              ]
            }
          }
        },
        {
          "type": "object",
          "description": "Keyed mapping marker: [key: <keyType>]",
          "required": ["kind", "keyType"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "key" },
            "keyType": {
              "type": "string",
              "description": "Name of the type used as the map key"
            }
          }
        },
        {
          "type": "object",
          "description": "Explicit cardinality bounds marker: [n1, n2]",
          "required": ["kind", "min", "max"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "range" },
            "min": { "type": "number" },
            "max": {
              "description": "Upper bound; use null for unbounded (*)",
              "oneOf": [{ "type": "number" }, { "type": "null" }]
            }
          }
        }
      ]
    },
    "longSemanticHeading": {
      "type": "string",
      "enum": [
        "Constraint",
        "Derivation",
        "Note"
      ],
      "description": "Long semantic note heading type. Note: Method/Overload/Instances are reserved for future phases when types support attributes/operations."
    },
    "partitionCompleteness": {
      "type": "string",
      "enum": ["complete", "incomplete"],
      "description": "Whether the generalization partition is complete (double bottom line) or incomplete (single bottom line)"
    },
    "relationEnd": {
      "type": "object",
      "description": "Relation endpoint connecting to a type",
      "required": ["typeId", "cardinality"],
      "properties": {
        "typeId": {
          "type": "string",
          "description": "ID of the connected type"
        },
        "cardinality": {
          "$ref": "#/definitions/cardinality"
        },
        "cardinalityRange": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 2,
          "maxItems": 2,
          "description": "Custom range [min, max] when cardinality is 'range'"
        }
      },
      "additionalProperties": false
    },
    "typeElement": {
      "type": "object",
      "description": "A Type node (core concept in Martin Fowler notation)",
      "required": ["id", "type", "name", "layout"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique element identifier"
        },
        "type": {
          "type": "string",
          "enum": ["type"],
          "description": "Element type discriminator"
        },
        "name": {
          "type": "string",
          "description": "Type name displayed in the rectangle"
        },
        "semantics": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/shortSemantic"
          },
          "description": "Short semantic statement markers attached to this type",
          "default": []
        },
        "layout": {
          "$ref": "#/definitions/layout"
        }
      }
    },
    "relationLayout": {
      "description": "Layout information for relation lines - separate from semantics",
      "type": "object",
      "properties": {
        "controlPoints": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/point"
          },
          "description": "Optional control points for manual path adjustment (Bezier curve)"
        },
        "sourceLabelOffset": {
          "$ref": "#/definitions/point",
          "description": "Offset of source cardinality label from default position"
        },
        "targetLabelOffset": {
          "$ref": "#/definitions/point",
          "description": "Offset of target cardinality label from default position"
        },
        "semanticLabelOffset": {
          "$ref": "#/definitions/point",
          "description": "Offset of semantic marker label from default position"
        }
      },
      "additionalProperties": false
    },
    "relationElement": {
      "type": "object",
      "description": "A relationship between two types with cardinality constraints on both ends",
      "required": ["id", "type", "source", "target"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique element identifier"
        },
        "type": {
          "type": "string",
          "enum": ["relation"],
          "description": "Element type discriminator"
        },
        "source": {
          "$ref": "#/definitions/relationEnd",
          "description": "Source end of the relation"
        },
        "target": {
          "$ref": "#/definitions/relationEnd",
          "description": "Target end of the relation"
        },
        "isDerived": {
          "type": "boolean",
          "description": "Whether this relation is derived (marked with / on the line)",
          "default": false
        },
        "semantics": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/shortSemantic"
          },
          "description": "Short semantic statement markers attached to this relation",
          "default": []
        },
        "layout": {
          "$ref": "#/definitions/relationLayout",
          "description": "Layout information for the relation line"
        }
      }
    },
    "generalizationElement": {
      "type": "object",
      "description": "A generalization partition - container for child types connected to a parent type",
      "required": ["id", "type", "parentTypeId", "childTypeIds", "completeness", "layout"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique element identifier"
        },
        "type": {
          "type": "string",
          "enum": ["generalization"],
          "description": "Element type discriminator"
        },
        "parentTypeId": {
          "type": "string",
          "description": "ID of the parent type"
        },
        "childTypeIds": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "IDs of child types inside this partition"
        },
        "completeness": {
          "$ref": "#/definitions/partitionCompleteness",
          "description": "Whether this is a complete (all instances accounted for) or incomplete partition"
        },
        "semantics": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/shortSemantic"
          },
          "description": "Short semantic statement markers attached to this generalization",
          "default": []
        },
        "layout": {
          "$ref": "#/definitions/layout"
        }
      }
    },
    "noteElement": {
      "type": "object",
      "description": "A long semantic statement in a folded note box",
      "required": ["id", "type", "heading", "content", "layout"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique element identifier"
        },
        "type": {
          "type": "string",
          "enum": ["note"],
          "description": "Element type discriminator"
        },
        "heading": {
          "$ref": "#/definitions/longSemanticHeading",
          "description": "Note category heading"
        },
        "content": {
          "type": "string",
          "description": "The content text of the note"
        },
        "attachedTo": {
          "type": "string",
          "description": "Optional ID of the element this note is attached to"
        },
        "layout": {
          "$ref": "#/definitions/layout"
        }
      }
    }
  }
}
